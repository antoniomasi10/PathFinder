# ===== PRODUCTION ENVIRONMENT =====
# Copy this to .env and fill in real values
# NEVER commit the actual .env file

# --- Database ---
POSTGRES_DB=pathfinder
POSTGRES_USER=pathfinder
POSTGRES_PASSWORD=   # REQUIRED: strong random password

# --- Backend ---
DATABASE_URL=         # REQUIRED: full postgresql connection string
JWT_SECRET=           # REQUIRED: generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_REFRESH_SECRET=   # REQUIRED: generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
FRONTEND_URL=         # REQUIRED: e.g. https://pathfinder.vercel.app
NODE_ENV=production
PORT=4000
LOG_LEVEL=info

# --- Frontend (Vercel) ---
NEXT_PUBLIC_API_URL=  # REQUIRED: e.g. https://api.pathfinder.example.com
