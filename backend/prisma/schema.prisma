generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GpaRange {
  GPA_18_20
  GPA_21_24
  GPA_25_27
  GPA_28_30
}

enum EnglishLevel {
  A2
  B1_B2
  C1
  C2_PLUS
}

enum WillingnessToRelocate {
  YES
  MAYBE
  NO
}

enum OpportunityType {
  STAGE
  INTERNSHIP
  EXTRACURRICULAR
  EVENT
  FELLOWSHIP
}

enum CourseType {
  TRIENNALE
  MAGISTRALE
  CICLO_UNICO
}

enum NotificationType {
  FRIEND_REQUEST
  FRIEND_ACCEPTED
  NEW_MESSAGE
  NEW_OPPORTUNITY
  OPPORTUNITY_DEADLINE
  COURSE_DEADLINE
  COURSE_RECOMMENDED
  BADGE_UNLOCKED
  POST_LIKE
  POST_COMMENT
  COMMENT_REPLY
  GROUP_UPDATE
  SYSTEM
  GENERAL
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum VerificationCodeType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum GroupMemberRole {
  CREATOR
  MEMBER
}

model User {
  id                String                 @id @default(uuid())
  email             String                 @unique
  passwordHash      String?
  name              String
  googleId          String?                @unique
  provider          AuthProvider           @default(LOCAL)
  emailVerified     Boolean                @default(false)
  avatar            String?
  bio               String?
  universityId      String?
  university        University?            @relation(fields: [universityId], references: [id])
  courseOfStudy     String?
  yearOfStudy       Int?
  gpa               GpaRange?
  englishLevel      EnglishLevel?
  willingToRelocate WillingnessToRelocate?
  profileCompleted  Boolean                @default(false)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  profile                UserProfile?
  sentMessages           PathMatesMessage[] @relation("SentMessages")
  receivedMessages       PathMatesMessage[] @relation("ReceivedMessages")
  createdGroups          PathMatesGroup[]   @relation("GroupCreator")
  groupMemberships       GroupMember[]
  notifications          Notification[]
  sentFriendRequests     FriendRequest[]    @relation("FriendRequestFrom")
  receivedFriendRequests FriendRequest[]    @relation("FriendRequestTo")
  posts                  Post[]
  postLikes              PostLike[]
  postComments           PostComment[]
  savedOpportunities     Opportunity[]      @relation("SavedOpportunities")
  savedCourses           Course[]           @relation("SavedCourses")
  notificationPreference NotificationPreference?
  pushSubscriptions      PushSubscription[]
  badges                 UserBadge[]
  tracking               UserTracking[]
  verificationCodes      VerificationCode[]

  @@index([universityId])
  @@index([googleId])
}

model UserProfile {
  id                  String    @id @default(uuid())
  userId              String    @unique
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  primaryInterest     String?
  naturalActivity     String?
  freeTimeActivity    String?
  problemSolvingStyle String?
  riskTolerance       String?
  careerVision        String?
  professionalGoal    String?
  passions            String[]
  clusterTag          String?
  completedAt         DateTime?
}

model Opportunity {
  id                   String          @id @default(uuid())
  title                String
  description          String
  about                String?
  url                  String?
  type                 OpportunityType
  universityId         String?
  university           University?     @relation(fields: [universityId], references: [id])
  company              String?
  location             String?
  isRemote             Boolean         @default(false)
  isAbroad             Boolean         @default(false)
  requiredEnglishLevel EnglishLevel?
  minGpa               GpaRange?
  tags                 String[]
  deadline             DateTime?
  postedAt             DateTime        @default(now())
  expiresAt            DateTime?
  savedBy              User[]          @relation("SavedOpportunities")
  sourceId             String?         // e.g. "eures-12345" — null = manual/seed
  lastSyncedAt         DateTime?       // last time this record was refreshed by import

  @@index([universityId])
  @@index([type])
  @@index([deadline])
  @@index([sourceId])
  @@index([lastSyncedAt])
}

model University {
  id            String        @id @default(uuid())
  name          String
  city          String
  country       String        @default("Italia")
  logoUrl       String?
  imageUrl      String?
  description   String?
  websiteUrl    String?
  alumniCount   Int           @default(0)
  avgRating     Float         @default(0)
  isActive      Boolean       @default(true)
  sourceId      String?       // e.g. "mur-00001" — null = manual/seed
  lastSyncedAt  DateTime?
  users         User[]
  courses       Course[]
  opportunities Opportunity[]

  @@index([sourceId])
}

model Course {
  id                         String     @id @default(uuid())
  universityId               String
  university                 University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  name                       String
  type                       CourseType
  field                      String?
  employmentRate             Float?
  avgSalaryAfterGraduation   Int?
  internshipsAvailable       Int?
  internationalOpportunities Boolean    @default(false)
  programDuration            String?
  languageOfInstruction      String?
  tags                       String[]   @default([])
  savedBy                    User[]     @relation("SavedCourses")
  isActive                   Boolean    @default(true)
  sourceId                   String?
  lastSyncedAt               DateTime?

  @@index([sourceId])
}

model PathMatesMessage {
  id         String          @id @default(uuid())
  senderId   String
  sender     User            @relation("SentMessages", fields: [senderId], references: [id])
  receiverId String?
  receiver   User?           @relation("ReceivedMessages", fields: [receiverId], references: [id])
  groupId    String?
  group      PathMatesGroup? @relation(fields: [groupId], references: [id])
  content    String
  images     String[]        @default([])
  sentAt     DateTime        @default(now())
  readAt     DateTime?

  @@index([senderId])
  @@index([receiverId])
  @@index([groupId])
  @@index([senderId, receiverId])
}

model PathMatesGroup {
  id          String             @id @default(uuid())
  name        String
  description String?
  image       String?
  createdById String
  createdBy   User               @relation("GroupCreator", fields: [createdById], references: [id])
  members     GroupMember[]
  messages    PathMatesMessage[]
  createdAt   DateTime           @default(now())
}

model GroupMember {
  id       String          @id @default(uuid())
  groupId  String
  group    PathMatesGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId   String
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     GroupMemberRole @default(MEMBER)
  joinedAt DateTime        @default(now())

  @@unique([groupId, userId])
  @@index([userId])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  content   String
  isRead    Boolean          @default(false)
  linkTo    String?
  icon      String?
  data      Json?
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
}

model FriendRequest {
  id         String              @id @default(uuid())
  fromUserId String
  fromUser   User                @relation("FriendRequestFrom", fields: [fromUserId], references: [id])
  toUserId   String
  toUser     User                @relation("FriendRequestTo", fields: [toUserId], references: [id])
  status     FriendRequestStatus @default(PENDING)
  createdAt  DateTime            @default(now())

  @@unique([fromUserId, toUserId])
  @@index([fromUserId])
  @@index([toUserId])
  @@index([status])
}

model Post {
  id        String        @id @default(uuid())
  authorId  String
  author    User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  images    String[]      @default([])
  createdAt DateTime      @default(now())
  likes     PostLike[]
  comments  PostComment[]

  @@index([authorId])
  @@index([createdAt])
}

model PostLike {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
}

model PostComment {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@index([postId])
}

model NotificationPreference {
  id             String  @id @default(uuid())
  userId         String  @unique
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  pushEnabled    Boolean @default(true)
  networking     Boolean @default(true)
  opportunities  Boolean @default(true)
  universities   Boolean @default(true)
  social         Boolean @default(true)
  postLikes      Boolean @default(false)
  chat           Boolean @default(true)
  achievements   Boolean @default(true)
  system         Boolean @default(true)
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
}

model UserBadge {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId    String
  progress   Int      @default(0)
  unlockedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, badgeId])
  @@index([userId])
}

model UserTracking {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  key       String
  value     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([userId, key])
  @@index([userId])
}

model ImportLog {
  id        String   @id @default(uuid())
  source    String   // mur, eures, almalaurea, istat
  type      String   // universities, courses, opportunities, stats
  status    String   // success, partial, failed
  count     Int      @default(0)
  error     String?
  startedAt DateTime @default(now())
  finishedAt DateTime?
  metadata  Json?

  @@index([source, type])
  @@index([startedAt])
}

model VerificationCode {
  id        String               @id @default(uuid())
  userId    String
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String
  type      VerificationCodeType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime             @default(now())

  @@index([userId, type])
  @@index([code, type])
}
