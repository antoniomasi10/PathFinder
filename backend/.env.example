# Database - use strong credentials in production
DATABASE_URL=postgresql://pathfinder:pathfinder@localhost:5432/pathfinder

# JWT Secrets - MUST be strong random strings (32+ chars) in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here

# Frontend URL - REQUIRED in production
FRONTEND_URL=http://localhost:3000

# Server port
PORT=4000

# Node environment
NODE_ENV=development

# Email (SMTP) — Required for email verification and password reset
# Use SendGrid, AWS SES, Mailgun, or any SMTP provider
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
EMAIL_FROM_NAME=PathFinder
EMAIL_FROM_ADDRESS=noreply@yourdomain.com

# Redis — Required for horizontal scaling (Socket.IO adapter + rate limiting)
REDIS_URL=redis://localhost:6379

# Cloudinary — Required for image storage in production
# Get credentials at https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Google OAuth — Required for "Continua con Google"
# Get credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# DeepL Translation — Optional, enables automatic translation of imported opportunities
# Free tier: 500,000 characters/month (sufficient for ~500–1,000 new opportunities/month)
# Get your key at https://www.deepl.com/pro-api (free plan available)
# Free plan keys end with ":fx"  |  Pro plan keys do not
DEEPL_API_KEY=your-deepl-api-key-here
