# Database - use strong credentials in production
DATABASE_URL=postgresql://pathfinder:pathfinder@localhost:5432/pathfinder

# JWT Secrets - MUST be strong random strings (32+ chars) in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here

# Frontend URL - REQUIRED in production
FRONTEND_URL=http://localhost:3000

# Server port
PORT=4000

# Node environment
NODE_ENV=development
